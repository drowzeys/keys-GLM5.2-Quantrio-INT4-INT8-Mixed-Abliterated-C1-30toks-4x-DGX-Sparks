# =============================================================================
# Cluster config for standing GLM-5.2 Quantrio Abliterated (firm L50–77 / max_num_seqs=4 / C1≈30.5)
# =============================================================================
# Copy to recipe/cluster.env and edit, OR export the same variables in your shell.
#
#   cp recipe/cluster.env.example recipe/cluster.env
#   $EDITOR recipe/cluster.env
#   bash scripts/oneshot.sh --all
#
# Head node = first IP in NODES. Run oneshot / launch FROM the head node.
# =============================================================================

# --- Nodes (REQUIRED for multi-node) — head FIRST ---
# Example keyspark fleet (replace with YOUR fabric IPs):
# NODES="10.100.10.4 10.100.10.1 10.100.10.2 10.100.10.3"
NODES="REPLACE_HEAD REPLACE_W1 REPLACE_W2 REPLACE_W3"

# SSH (passwordless key auth from head → every worker)
SSH_USER="REPLACE_USER"                 # usually the same user on all Sparks
SSH_KEY="$HOME/.ssh/id_ed25519"

# --- Paths (same absolute path on every node) ---
WEIGHTS_DIR=/var/tmp/models
ABLIT_DIR=/var/tmp/models/glm52-int4-int8mix-abliterated
KERNELS_DIR=$HOME/glm-triton
NCCL_DIR=/var/tmp/models/hub/nccl-2.30.4

# --- Image ---
GHCR_IMAGE=ghcr.io/drowzeys/vllm-node-tf5-glm52-b12x:speed1-c1-30-128k
IMAGE=vllm-node-tf5-glm52-b12x:probe-modded
NAME=vllm_qt200k
PORT=8210
MASTER_PORT=29501

# --- RoCE fabric (run: bash scripts/detect_fabric.sh) ---
# ibdev2netdev  → HCA + netdev that is (Up)
# show_gids     → RoCEv2 GID index if 3 is wrong
NCCL_IB_HCA=rocep1s0f1
NCCL_SOCKET_IFNAME=enp1s0f1np1
GLOO_SOCKET_IFNAME=enp1s0f1np1
NCCL_IB_GID_INDEX=3

# --- Standing firm serve knobs (validated C1≈30.5 @ max_num_seqs=4, 128k) ---
# UTIL 0.86 is an explicit exception for this GLM-5.2 profile (do not raise further).
SPEED=0
MAX_NUM_SEQS=4
MTP_K=4
MAX_MODEL_LEN=128000
UTIL=0.86
KV_BYTES=7008000000
LAYERING=0

# --- HF (gated ablit weights) ---
# export HF_TOKEN=hf_...   # required unless SKIP_DOWNLOAD=1 with tree already present
HF_REPO=drowzeys/GLM-5.2-Int4-Int8Mix-Abliterated
